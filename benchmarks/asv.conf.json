{
    "version": 1,
    "project": "squidpy",
    "project_url": "https://squidpy.readthedocs.io/",
    "repo": "..",

    "build_command": [
        "python -m pip install build",
        "python -m build --wheel -o {build_cache_dir} {build_dir}"
    ],
    "install_command": ["python -m pip install {wheel_file}"],

    "branches": ["main"],
    "dvcs": "git",

    // uv plugin (PR #1544) is not yet merged into asv.
    // Switch to "uv" once asv ships the plugin.
    "environment_type": "virtualenv",

    "show_commit_url": "https://github.com/scverse/squidpy/commit/",

    "matrix": {
        "req": {},
        "env": {}
    },

    "env_dir": ".asv/env",
    "results_dir": ".asv/results",
    "html_dir": ".asv/html"
}
